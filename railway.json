{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd server && npm install && npm run build",
    "outDir": "server/dist"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "env": {
      "NODE_ENV": "production",
      "PORT": {
        "runtime": "FROM_VAR",
        "varName": "PORT"
      }
    }
  }
}
